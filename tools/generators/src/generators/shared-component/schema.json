{
  "$schema": "https://json-schema.org/schema",
  "$id": "SharedComponent",
  "title": "Genera un componente standalone en libs/shared",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nombre del componente",
      "$default": { "$source": "argv", "index": 0 },
      "x-prompt": "¿Nombre del componente?"
    },
  },
  "required": ["name"]
}
