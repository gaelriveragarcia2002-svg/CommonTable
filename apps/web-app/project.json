{
  "name": "web-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/web-app/src",
  "tags": [],
  // TODO: Al agregar un nuevo idioma:
  // 1. Añadir entrada aquí con el código de locale (ej: "de", "pt", "it")
  // 2. Crear libs/i18n/messages.<locale>.xlf copiando la estructura de messages.en.xlf
  // 3. Agregar configuración "fr"/"de"/etc. en build.configurations y serve.configurations
  // 4. Actualizar SUPPORTED_LOCALES en scripts/i18n-merge.mjs
  "i18n": {
    "sourceLocale": "es",
    "locales": {
      "en": {
        "translation": "libs/i18n/messages.en.xlf"
      },
      "fr": {
        "translation": "libs/i18n/messages.fr.xlf"
      }
    }
  },
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/web-app",
        "browser": "apps/web-app/src/main.ts",
        "tsConfig": "apps/web-app/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/web-app/public"
          }
        ],
        "styles": [
          "apps/web-app/src/styles.css",
          "node_modules/@fortawesome/fontawesome-free/css/all.css"
        ],
        "server": "apps/web-app/src/main.server.ts",
        "ssr": {
          "entry": "apps/web-app/src/server.ts"
        },
        "polyfills": ["@angular/localize/init"],
        "outputMode": "server"
        // TODO (producción): Agregar bloque "security" cuando tengas el dominio final:
        // "security": { "allowedHosts": ["tudominio.com"] }
        // Esto previene ataques SSRF a nivel de build (alternativa a NG_ALLOWED_HOSTS en runtime).
      },
      "configurations": {
        "production": {
          // TODO: Revisar budgets antes de cada release. Si el bundle supera el límite
          // el build fallará. Aumentar maximumError solo si hay justificación (librerías pesadas).
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          // TODO (producción): Cuando el proyecto esté listo para i18n en prod,
          // agregar "localize": true aquí para buildear todos los locales en producción.
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/web-app/src/environments/environment.development.ts",
              "with": "apps/web-app/src/environments/environment.production.ts"
            }
          ]
        },
        "qa": {
          // TODO (qa): Mismo criterio que producción para budgets.
          // Considerar bajar los límites en QA para detectar problemas antes de producción.
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/web-app/src/environments/environment.development.ts",
              "with": "apps/web-app/src/environments/environment.qa.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "localize": false
        },
        "en": {
          "localize": ["en"]
        }
      },
      "defaultConfiguration": "production"
    },
    "build-spa": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/web-app",
        "browser": "apps/web-app/src/main.ts",
        "tsConfig": "apps/web-app/tsconfig.app.json",
        "polyfills": ["@angular/localize/init"],
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/web-app/public"
          }
        ],
        "styles": [
          "apps/web-app/src/styles.css",
          "node_modules/@fortawesome/fontawesome-free/css/all.css"
        ]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/web-app/src/environments/environment.development.ts",
              "with": "apps/web-app/src/environments/environment.production.ts"
            }
          ]
        },
        "qa": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/web-app/src/environments/environment.development.ts",
              "with": "apps/web-app/src/environments/environment.qa.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "development": {
          "buildTarget": "web-app:build:development"
        },
        "qa": {
          "buildTarget": "web-app:build:qa"
        },
        "production": {
          "buildTarget": "web-app:build:production"
        },
        "development-no-ssr": {
          "buildTarget": "web-app:build-spa:development"
        },
        "qa-no-ssr": {
          "buildTarget": "web-app:build-spa:qa"
        },
        "production-no-ssr": {
          "buildTarget": "web-app:build-spa:production"
        },
        "en": {
          "buildTarget": "web-app:build:development,en"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "web-app:build",
        "outputPath": "libs/i18n",
        "outFile": "messages.xlf",
        "format": "xlf"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {}
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "web-app:build",
        "port": 4200,
        "staticFilePath": "dist/apps/web-app/browser",
        "spa": true
      }
    }
  }
}
